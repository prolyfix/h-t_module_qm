{% extends '@EasyAdmin/crud/detail.html.twig' %}

{% block main %}
    <h1 class="mt-2">
        {{ entity.instance.title }}
    </h1>
    {{ entity.instance.description|raw }}

    {% if entity.instance.children|length > 0 %}
    <div class="card mt-4">
        <div class="card-header d-flex align-items-center gap-2" style="background-color:#f672a7;color:#fff;">
            <i class="fas fa-sitemap"></i>
            <strong>
                {{ 'qm.paragraph_detail.child_paragraphs'|trans }}
            </strong>
            <span class="badge bg-white ms-1" style="color:#f672a7;">
                {{ entity.instance.children|length }}
            </span>
        </div>
        <div class="card-body p-0">
            <div class="list-group list-group-flush">
                {% for child in entity.instance.children|sort((a, b) => (a.creationDate ? a.creationDate|date('U') : 0) <=> (b.creationDate ? b.creationDate|date('U') : 0)) %}
                    <a href="{{ ea_url().setController('Prolyfix\\QmBundle\\Controller\\Admin\\ParagraphCrudController').setEntityId(child.id).setAction('detail') }}" class="list-group-item list-group-item-action d-flex align-items-center">
                        <span class="me-2" style="color:#f672a7;"><i class="fas fa-angle-right"></i></span>
                        <span class="flex-grow-1">{{ child.title }}</span>
                        {% if child.totalActionsCount > 0 %}
                            <span class="badge rounded-pill bg-light text-dark me-2">{{ child.doneActionsCount }}/{{ child.totalActionsCount }}</span>
                        {% endif %}
                        <small class="text-muted">{{ child.creationDate ? child.creationDate|date('Y-m-d H:i') : '' }}</small>
                    </a>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    {% if entity.instance.totalActionsCount > 0 %}
    <div class="card mt-4">
        <div class="card-header d-flex align-items-center gap-2" style="background-color:#f672a7;color:#fff;">
            <i class="fas fa-tasks"></i>
            <strong>
                {{ 'qm.paragraph_detail.actions'|trans }}
            </strong>
            <span class="badge bg-white ms-1" style="color:#f672a7;">
                {{ entity.instance.doneActionsCount }}/{{ entity.instance.totalActionsCount }}
            </span>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-center" style="width:70px;">{{ 'qm.paragraph_detail.done'|trans }}</th>
                        <th>{{ 'qm.paragraph_detail.indication'|trans }}</th>
                        <th>{{ 'qm.paragraph_detail.hint'|trans }}</th>
                        <th style="width:170px;">{{ 'qm.paragraph_detail.created'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for action in entity.instance.actionsOrderedByCreationDate %}
                        <tr>
                            <td class="text-center">
                                <input
                                    type="checkbox"
                                    class="form-check-input qm-action-done-toggle"
                                    data-action-id="{{ action.id }}"
                                    {{ action.done ? 'checked' : '' }}
                                >
                            </td>
                            <td>{{ action.indication }}</td>
                            <td>{{ action.hint ?: '—' }}</td>
                            <td class="text-muted">{{ action.creationDate ? action.creationDate|date('Y-m-d H:i') : '' }}</td>
                        </tr>
                        {% if action.comment %}
                        <tr class="table-warning">
                            <td colspan="4" class="ps-3 py-1">
                                <i class="fas fa-comment-alt me-1 text-muted"></i>
                                <span>{{ action.comment }}</span>
                                {% if action.commentDate %}
                                    <small class="text-muted ms-2">({{ action.commentDate|date('Y-m-d H:i') }})</small>
                                {% endif %}
                            </td>
                        </tr>
                        {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    <script>
    (function () {
        async function patchActionDone(actionId, done) {
            const response = await fetch('/api/actions/' + actionId, {
                method: 'PATCH',
                credentials: 'same-origin',
                headers: {
                    'Accept': 'application/ld+json',
                    'Content-Type': 'application/merge-patch+json'
                },
                body: JSON.stringify({ done: done })
            });

            if (!response.ok) {
                throw new Error('PATCH failed: ' + response.status);
            }

            const payload = await response.json();
            const persistedDone = typeof payload.done === 'boolean'
                ? payload.done
                : (typeof payload.isDone === 'boolean' ? payload.isDone : null);

            if (persistedDone === null || persistedDone !== done) {
                throw new Error('Server validation failed');
            }
        }

        document.addEventListener('change', function (event) {
            const target = event.target;
            if (!(target instanceof HTMLInputElement) || !target.classList.contains('qm-action-done-toggle')) {
                return;
            }

            const actionId = target.dataset.actionId;
            if (!actionId) {
                return;
            }

            const previousValue = !target.checked;
            const desiredValue = target.checked;
            target.disabled = true;

            patchActionDone(actionId, desiredValue)
                .catch(function () {
                    target.checked = previousValue;
                    window.alert('{{ 'qm.paragraph_detail.could_not_update_action_status'|trans|e('js') }}');
                })
                .finally(function () {
                    target.disabled = false;
                });
        });
    })();
    </script>


    {# ── Linked documents overview ── #}
    {% if paragraphInstance is defined %}
    <div class="card mt-4">
        <div class="card-header d-flex align-items-center gap-2" style="background-color:#f672a7;color:#fff;">
            <i class="fas fa-book-open"></i>
            <strong>
                {{ 'qm.paragraph_detail.linked_documents'|trans }}
            </strong>
            {% if linkedEntities is defined %}
                <span class="badge bg-white ms-1" style="color:#f672a7;">
                    {{ linkedEntities|length }}
                </span>
            {% endif %}
            <span class="ms-auto" data-controller="modal-form">
                <a href="{{ path('qm_paragraph_attach_media', {paragraphId: paragraphInstance.id}) }}" class="btn btn-sm" data-action="click->modal-form#openModal" data-url="{{ path('qm_paragraph_attach_media', {paragraphId: paragraphInstance.id}) }}" style="background-color:#fff;color:#f672a7;border:none;">
                    <i class="fas fa-paperclip me-1"></i>
                    {{ 'qm.paragraph_detail.attach_file'|trans }}
                </a>
            </span>
        </div>
        <div class="card-body p-0">
            {% if linkedEntities is defined and linkedEntities|length > 0 %}
            <table class="table table-hover table-sm mb-0" id="qm-linked-entities-table">
                    <thead class="table-light">
                        <tr>
                            <th>
                                {{ 'qm.paragraph_detail.entity'|trans }}
                            </th>
                            <th>
                                {{ 'qm.paragraph_detail.name_or_id'|trans }}
                            </th>
                            <th>
                                {{ 'qm.paragraph_detail.document_type'|trans }}
                            </th>
                            <th class="text-center">
                                {{ 'qm.paragraph_detail.template'|trans }}
                            </th>
                            <th class="text-end">
                                {{ 'qm.paragraph_detail.actions'|trans }}
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for le in linkedEntities %}
                            {% set isMedia = le.entity ends with 'Media' %}
                            <tr>
                                <td>
                                    <span class="badge" style="background-color:#f672a7;">
                                        {{ le.entity|split('\\')|last }}
                                    </span>
                                </td>
                                <td>
                                    {% if isMedia %}
                                        {% set media = le.entityId %}
                                        <i class="fas fa-file text-muted me-1"></i>
                                        {{ le.entityId }}
                                    {% else %}
                                        {{ le.entityId }}
                                    {% endif %}
                                </td>
                                <td>
                                    {{ le.documentType ?? '—' }}
                                </td>
                                <td class="text-center">
                                    {% if le.isTemplate %}
                                        <i class="fas fa-check-circle text-success"></i>
                                    {% else %}
                                        <i class="fas fa-times-circle text-muted"></i>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    {% if le.url is not null %}
                                        <a href="{{ le.url }}" target="_blank" class="btn btn-xs btn-sm" style="background-color:#f672a7;color:#fff;">
                                            <i class="fas fa-link me-1"></i>
                                            {{ 'qm.paragraph_detail.link'|trans }}
                                        </a>
                                    {% endif %}

                                    {% if linkedDocumentUrls is defined and linkedDocumentUrls[le.id] is defined %}
                                        <a href="{{ linkedDocumentUrls[le.id] }}" class="btn btn-xs btn-sm" style="background-color:#f672a7;color:#fff;">
                                            <i class="fas fa-external-link-alt me-1"></i>
                                            {{ 'qm.paragraph_detail.open'|trans }}
                                        </a>
                                    {% endif %}

                                    {% if isMedia %}
                                        <a href="{{ path('qm_media_download', {mediaId: le.entityId}) }}" class="btn btn-xs btn-sm" style="background-color:#f672a7;color:#fff;">
                                            <i class="fas fa-download"></i>
                                        </a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
            </table>

                {# Client-side pagination controls (shown only when >10 rows) #}
            {% if linkedEntities|length > 10 %}
                    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
                        <small class="text-muted qm-page-info"></small>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-secondary" id="qm-prev-page" type="button">
                                &laquo; {{ 'qm.paragraph_detail.prev'|trans }}
                            </button>
                            <button class="btn btn-outline-secondary" id="qm-next-page" type="button">
                                {{ 'qm.paragraph_detail.next'|trans }} &raquo;
                            </button>
                        </div>
                    </div>
                    <script>
                    (function () {
                        const perPage = 10;
                        let page = 0;
                        const rows = Array.from(document.querySelectorAll('#qm-linked-entities-table tbody tr'));
                        const info = document.querySelector('.qm-page-info');
                        function render() {
                            rows.forEach((r, i) => r.style.display = (i >= page * perPage && i < (page + 1) * perPage) ? '' : 'none');
                            info.textContent = '{{ 'qm.paragraph_detail.showing'|trans|e('js') }} ' + (page * perPage + 1) + '–' + Math.min((page + 1) * perPage, rows.length) + ' {{ 'qm.paragraph_detail.of'|trans|e('js') }} ' + rows.length;
                            document.getElementById('qm-prev-page').disabled = page === 0;
                            document.getElementById('qm-next-page').disabled = (page + 1) * perPage >= rows.length;
                        }
                        document.getElementById('qm-prev-page').addEventListener('click', () => { if (page > 0) { page--; render(); } });
                        document.getElementById('qm-next-page').addEventListener('click', () => { if ((page + 1) * perPage < rows.length) { page++; render(); } });
                        render();
                    })();
                    </script>
            {% endif %}
            {% else %}
                <p class="text-muted p-3 mb-0">{{ 'qm.paragraph_detail.no_linked_documents_yet'|trans }}</p>
            {% endif %}
        </div>
    </div>
    {% endif %}
{% endblock %}
